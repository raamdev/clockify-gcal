# Server
PORT=8080
BASE_URL=https://your-public-url.ngrok.io

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set redirect URI to: ${BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Addon security
# A random secret used to validate incoming webhook signatures from Clockify
ADDON_WEBHOOK_SECRET=change_this_to_a_random_string

# Database path
DB_PATH=./data/addon.db
